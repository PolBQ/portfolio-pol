{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "@components/*": [
    "src/components/*"
  ],
  "@layouts/*": [
    "src/layouts/*"
  ],
  "@styles/*": [
    "src/styles/*"
  ],
  "@lib/*": [
    "src/lib/*"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}