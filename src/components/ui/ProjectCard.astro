---
const { title, description, tech, github } = Astro.props;
---

<div
  class="border border-zinc-800 rounded-2xl p-6 hover:border-zinc-600 transition bg-zinc-900"
>
  <h3 class="text-2xl font-semibold mb-4">
    {title}
  </h3>

  <p class="text-zinc-400 mb-6 leading-relaxed">
    {description}
  </p>

  <div class="flex flex-wrap gap-2 mb-6">
    {
      tech.map((item: string) => (
        <span class="bg-zinc-800 px-3 py-1 rounded-lg text-sm">
          {item}
        </span>
      ))
    }
  </div>

  <a
    href={github}
    target="_blank"
    class="text-blue-500 hover:text-blue-400"
  >
    View Repository →
  </a>
</div>