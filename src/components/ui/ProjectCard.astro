---
const {
  title,
  description,
  tags,
  image,
  slug,
} = Astro.props;
---

<a
  href={`/projects/${slug}`}
  class="block border border-zinc-800 rounded-2xl overflow-hidden hover:border-zinc-600 transition bg-zinc-900"
>

  <img
    src={image}
    alt={title}
    class="w-full h-52 object-cover"
    loading="lazy"
  />

  <div class="p-6">

    <h3 class="text-2xl font-semibold mb-4 text-white">
      {title}
    </h3>

    <p class="text-zinc-400 mb-6 leading-relaxed">
      {description}
    </p>

    <div class="flex flex-wrap gap-2">

      {
        tags.map((tag: string) => (
          <span class="bg-zinc-800 px-3 py-1 rounded-lg text-sm text-zinc-300">
            {tag}
          </span>
        ))
      }

    </div>

  </div>

</a>