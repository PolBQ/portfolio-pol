---
const year = new Date().getFullYear();
import { asset } from "../../lib/assets";
---

<section
  class="
    container-base

    relative
    overflow-hidden

    mt-24

    rounded-t-[25px]

    border
    border-slate-800/80
  "
>

  <!-- BACKGROUND -->

  <div class="absolute inset-0 -z-10">

    <!-- BASE -->

    <div class="
      absolute inset-0

      bg-gradient-to-br
      from-slate-950
      via-slate-900
      to-slate-950
    "></div>

    <!-- TOP LIGHT -->

    <div class="
      absolute

      top-[-120px]
      right-[-80px]

      w-[420px]
      h-[420px]

      rounded-full

      bg-blue-500/10

      blur-3xl

      opacity-20
    "></div>

    <!-- BOTTOM LIGHT -->

    <div class="
      absolute

      bottom-[-140px]
      left-[-100px]

      w-[320px]
      h-[320px]

      rounded-full

      bg-cyan-500/10

      blur-3xl

      opacity-10
    "></div>

  </div>

  <!-- CONTENT -->

  <div
    class="
      relative
      z-10

      flex
      flex-col
      lg:flex-row

      items-center
      justify-between

      gap-6

      px-6
      lg:px-10

      py-6
      lg:py-7
    "
  >

    <!-- LEFT -->

    <div
      class="
        text-center
        lg:text-left
      "
    >

      <p
        class="
          text-sm

          tracking-[0.02em]

          text-slate-400
        "
      >
        Artificial Intelligence • Embedded Systems • Research
      </p>

    </div>

    <!-- LINKS -->

    <div
      class="
        flex
        flex-wrap

        justify-center
        lg:justify-end

        gap-3
      "
    >

      <!-- GITHUB -->

      <a
        href="https://github.com/polbq"
        target="_blank"
        rel="noopener noreferrer"

        class="
          inline-flex
          items-center
          gap-2

          rounded-full

          border
          border-slate-700

          bg-slate-900/40

          px-4
          py-2.5

          text-sm
          font-medium

          text-slate-300

          backdrop-blur-sm

          transition-all
          duration-200

          hover:border-cyan-400/40
          hover:bg-slate-900/70
          hover:text-slate-100
        "
      >

        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-4 h-4"
        >
          <path d="M12 .5C5.65.5.5 5.66.5 12.02c0 5.1 3.3 9.42 7.88 10.95.58.1.8-.25.8-.57v-2.02c-3.2.7-3.88-1.37-3.88-1.37-.52-1.33-1.28-1.68-1.28-1.68-1.04-.72.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.75 2.68 1.25 3.34.95.1-.75.4-1.25.72-1.53-2.55-.3-5.23-1.28-5.23-5.68 0-1.25.45-2.27 1.18-3.07-.12-.3-.5-1.5.12-3.12 0 0 .97-.32 3.18 1.17a10.8 10.8 0 0 1 5.8 0c2.2-1.5 3.17-1.17 3.17-1.17.63 1.62.25 2.82.13 3.12.73.8 1.17 1.82 1.17 3.07 0 4.42-2.68 5.37-5.24 5.67.42.37.78 1.08.78 2.2v3.25c0 .32.2.68.8.57A11.53 11.53 0 0 0 23.5 12C23.5 5.66 18.35.5 12 .5z"/>
        </svg>

        <span>GitHub</span>

      </a>

      <!-- LINKEDIN -->

      <a
        href="https://www.linkedin.com/in/pol-alexander-ballesteros-quiroga-629165320/"
        target="_blank"
        rel="noopener noreferrer"

        class="
          inline-flex
          items-center
          gap-2

          rounded-full

          border
          border-slate-700

          bg-slate-900/40

          px-4
          py-2.5

          text-sm
          font-medium

          text-slate-300

          backdrop-blur-sm

          transition-all
          duration-200

          hover:border-cyan-400/40
          hover:bg-slate-900/70
          hover:text-slate-100
        "
      >

        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-4 h-4"
        >
          <path d="M4.98 3.5C4.98 4.88 3.86 6 2.48 6S0 4.88 0 3.5 1.12 1 2.48 1s2.5 1.12 2.5 2.5zM.5 8h4V24h-4V8zm7 0h3.8v2.2h.1c.5-.9 1.8-2.2 3.9-2.2 4.2 0 5 2.7 5 6.3V24h-4v-7.1c0-1.7 0-3.9-2.4-3.9s-2.7 1.8-2.7 3.7V24h-4V8z"/>
        </svg>

        <span>LinkedIn</span>

      </a>

      <!-- EMAIL -->

      <a
        href="mailto:pol.alexander.ballesteros.q@gmail.com"

        class="
          inline-flex
          items-center
          gap-2

          rounded-full

          border
          border-slate-700

          bg-slate-900/40

          px-4
          py-2.5

          text-sm
          font-medium

          text-slate-300

          backdrop-blur-sm

          transition-all
          duration-200

          hover:border-cyan-400/40
          hover:bg-slate-900/70
          hover:text-slate-100
        "
      >

        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.8"
          class="w-4 h-4"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16v12H4V6zm0 0 8 6 8-6"
          />
        </svg>

        <span>Email</span>

      </a>

      <!-- ORCID -->

      <a
        href="https://orcid.org/"
        target="_blank"
        rel="noopener noreferrer"

        class="
          inline-flex
          items-center
          gap-2

          rounded-full

          border
          border-slate-700

          bg-slate-900/40

          px-4
          py-2.5

          text-sm
          font-medium

          text-slate-300

          backdrop-blur-sm

          transition-all
          duration-200

          hover:border-emerald-400/40
          hover:bg-slate-900/70
          hover:text-slate-100
        "
      >

        <img
          src={asset("\images\icons\orcid.svg")}
          alt="ORCID"

          class="
            w-4
            h-4

            opacity-90
          "
        />

        <span>ORCID</span>

      </a>

    </div>

  </div>

  <!-- COPYRIGHT -->

  <div
    class="
      relative
      z-10
    "
  >

    <div
      class="
        px-6
        lg:px-10

        py-4
      "
    >

      <p
        class="
          text-center

          text-xs

          tracking-[0.02em]

          text-slate-500
        "
      >
        © {year} Pol Ballesteros. All rights reserved.
      </p>

    </div>

  </div>

</section>