---
const year = new Date().getFullYear();
---

<footer
  class="
    relative
    overflow-hidden
    border-t
    border-slate-800
    mt-20
  "
>

  <!-- BACKGROUND -->

  <div class="absolute inset-0 -z-10">

    <div class="
      absolute inset-0
      bg-gradient-to-br
      from-slate-950
      via-slate-900
      to-slate-950
    "></div>

    <div class="
      absolute top-0 left-0
      w-80 h-80
      bg-blue-500/10
      rounded-full
      blur-3xl
      opacity-20
    "></div>

    <div class="
      absolute bottom-0 right-0
      w-72 h-72
      bg-cyan-500/10
      rounded-full
      blur-3xl
      opacity-20
    "></div>

  </div>

  <!-- CONTENT -->

  <div
    class="
      container-base

      relative
      z-10

      flex
      flex-col
      lg:flex-row

      items-center
      justify-between

      gap-8

      py-10
    "
  >

    <!-- LEFT -->

    <div class="text-center lg:text-left">

      <h3
        class="
          text-lg
          font-semibold
          text-slate-100
        "
      >
        Pol Alexander Ballesteros Quiroga
      </h3>

      <p
        class="
          mt-2
          text-sm
          text-slate-400
        "
      >
        Artificial Intelligence · Embedded Systems · Research
      </p>

    </div>

    <!-- LINKS -->

    <div
      class="
        flex
        flex-wrap

        justify-center
        lg:justify-end

        gap-3
      "
    >

      <a
        href="https://github.com/polbq"
        target="_blank"
        class="
          border
          border-slate-700

          hover:border-blue-500

          transition
          duration-150

          px-4
          py-2

          rounded-xl

          text-sm
          text-slate-300

          hover:text-white
        "
      >
        GitHub
      </a>

      <a
        href="https://linkedin.com/"
        target="_blank"
        class="
          border
          border-slate-700

          hover:border-blue-500

          transition
          duration-150

          px-4
          py-2

          rounded-xl

          text-sm
          text-slate-300

          hover:text-white
        "
      >
        LinkedIn
      </a>

      <a
        href="mailto:pol.alexander.ballesteros.q@gmail.com"
        class="
          border
          border-slate-700

          hover:border-blue-500

          transition
          duration-150

          px-4
          py-2

          rounded-xl

          text-sm
          text-slate-300

          hover:text-white
        "
      >
        Email
      </a>

    </div>

  </div>

  <!-- COPYRIGHT -->

  <div
    class="
      relative
      z-10

      border-t
      border-slate-800
    "
  >

    <div
      class="
        container-base
        py-5
      "
    >

      <p
        class="
          text-center
          text-xs
          text-slate-500
        "
      >
        © {year} Pol Ballesteros. All rights reserved.
      </p>

    </div>

  </div>

</footer>