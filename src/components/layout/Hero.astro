---
import { asset } from "../../lib/assets";
---

<section
  class="
    container-base
    relative
    overflow-hidden
  "
>

  <!-- BACKGROUND -->

  <div class="absolute inset-0 -z-10">

    <div class="
      absolute inset-0
      bg-gradient-to-br
      from-slate-950
      via-slate-900
      to-slate-950
    "></div>

    <div class="
      absolute top-0 right-0
      w-96 h-96
      bg-blue-500/20
      rounded-full
      blur-3xl
      opacity-30
    "></div>

    <div class="
      absolute bottom-0 left-0
      w-72 h-72
      bg-cyan-500/10
      rounded-full
      blur-3xl
      opacity-20
    "></div>

  </div>

  <!-- CONTENT -->

  <div
    class="
      relative
      z-10

      flex
      flex-col
      lg:flex-row

      items-center
      lg:items-center

      justify-between

      gap-8
      lg:gap-16

      py-10
      lg:py-0

      min-h-[235px]
    "
  >

    <!-- LEFT -->

    <div
      class="
        flex
        flex-col
        sm:flex-row

        items-center
        sm:items-center

        text-center
        sm:text-left

        gap-5
        lg:gap-6

        w-full
        lg:w-auto
      "
    >

      <!-- IMAGE -->

      <img
        src={asset("/images/me/PolBallesteros.jpeg")}
        alt="Pol Ballesteros"
        class="
          w-24
          h-24
          lg:w-28
          lg:h-28

          rounded-full
          object-cover

          ring-2
          ring-blue-500/30

          flex-shrink-0
        "
      />

      <!-- TEXT -->

      <div>

        <p
          class="
            mb-3

            tracking-[0.18em]
            uppercase

            text-[10px]
            sm:text-[11px]

            text-slate-300
          "
        >
          Artificial Intelligence • Embedded Systems • Research
        </p>

        <h1
          class="
            text-2xl
            sm:text-3xl
            lg:text-4xl

            font-semibold

            leading-[1.05]
            tracking-tight

            text-slate-100
          "
        >
          Pol Alexander<br />
          Ballesteros Quiroga
        </h1>

      </div>

    </div>

    <!-- RIGHT -->

    <div
      class="
        flex
        flex-col

        items-center
        lg:items-end

        w-full
        lg:w-auto
      "
    >

      <!-- CTA -->

      <div
        class="
          flex
          flex-col
          sm:flex-row

          w-full
          sm:w-auto

          gap-3
        "
      >

        <a
          href={asset("/projects")}
          class="
            bg-accent
            hover:bg-accent-hover

            transition
            duration-150
            ease-out
            transform
            hover:-translate-y-0.5
            active:translate-y-0.5
            active:scale-95

            px-5
            py-3

            rounded-xl

            text-sm
            font-medium
            text-white

            text-center
            focus:outline-none
            focus:ring-2
            focus:ring-blue-400/40
          "
        >
          View Projects
        </a>

        <a
          href={asset("/documents/CV_PolBallesterosQ.pdf")}
          target="_blank"
          class="
            border
            border-border

            hover:border-accent
            hover:bg-slate-900/10

            transition
            duration-150
            ease-out
            transform
            hover:-translate-y-0.5
            active:translate-y-0.5
            active:scale-95

            px-5
            py-3

            rounded-xl

            text-sm
            font-medium
            text-slate-100

            text-center
            focus:outline-none
            focus:ring-2
            focus:ring-blue-400/30
          "
        >
          Download CV
        </a>

      </div>

    </div>

  </div>

</section>