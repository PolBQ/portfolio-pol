---
import { asset } from "../../lib/assets";
---

<section
  class="
    container-base

    relative
    overflow-hidden

    rounded-b-[25px]

    border
    border-slate-800/80
  "
>

  <!-- BACKGROUND -->

  <div class="absolute inset-0 -z-10">

    <div class="
      absolute inset-0
      bg-gradient-to-br
      from-slate-950
      via-slate-900
      to-slate-950
    "></div>

    <div class="
      absolute top-0 right-0
      w-96 h-96
      bg-blue-500/20
      rounded-full
      blur-3xl
      opacity-30
    "></div>

    <div class="
      absolute bottom-0 left-0
      w-72 h-72
      bg-cyan-500/10
      rounded-full
      blur-3xl
      opacity-20
    "></div>

  </div>

  <!-- CONTENT -->

  <div
    class="
      relative
      z-10

      flex
      flex-col
      lg:flex-row

      items-center
      justify-between

      gap-8
      lg:gap-14

      px-6
      lg:px-10

      py-8
      lg:py-9

      min-h-[220px]
    "
  >

    <!-- LEFT -->

    <div
      class="
        flex
        flex-col
        sm:flex-row

        items-center
        sm:items-center

        text-center
        sm:text-left

        gap-6
        lg:gap-7

        w-full
        lg:w-auto
      "
    >

      <!-- IMAGE -->

      <img
        src={asset("/images/me/PolBallesteros.jpeg")}
        alt="Pol Ballesteros"

        class="
          w-24
          h-24

          lg:w-28
          lg:h-28

          rounded-full
          object-cover

          border
          border-slate-700

          ring-1
          ring-blue-500/20

          shadow-[0_6px_18px_rgba(2,6,23,0.35)]

          flex-shrink-0
        "
      />

      <!-- TEXT -->

      <div
        class="
          max-w-[620px]
        "
      >

        <!-- LABEL -->

        <p
          class="
            mb-3

            tracking-[0.18em]
            uppercase

            text-[10px]
            sm:text-[11px]

            font-medium

            text-slate-400
          "
        >
          Artificial Intelligence • Embedded Systems • Research
        </p>

        <!-- TITLE -->

        <h1
          class="
            text-[1.8rem]
            sm:text-[2.2rem]
            lg:text-[2.6rem]

            font-semibold

            leading-[1]

            tracking-[-0.045em]

            text-slate-100
          "
        >
          Pol Alexander
          <br />
          Ballesteros Quiroga
        </h1>

      </div>

    </div>

    <!-- RIGHT -->

    <div
      class="
        flex
        flex-col

        items-center
        lg:items-end

        w-full
        lg:w-auto
      "
    >

      <!-- BUTTONS -->

      <div
        class="
          flex
          flex-col
          sm:flex-row

          w-full
          sm:w-auto

          gap-2.5
        "
      >

        <!-- PRIMARY -->

        <a
          href={asset("/projects")}

          class="
            inline-flex
            items-center
            justify-center

            rounded-full

            border
            border-blue-500/20

            bg-blue-500/10

            px-5
            py-2.5

            text-sm
            font-medium

            text-slate-100

            backdrop-blur-sm

            transition-all
            duration-200

            hover:border-blue-400/40
            hover:bg-blue-500/20
          "
        >
          View Projects
        </a>

        <!-- SECONDARY -->

        <a
          href={asset("/documents/CV_PolBallesterosQ.pdf")}
          target="_blank"

          class="
            inline-flex
            items-center
            justify-center

            rounded-full

            border
            border-slate-700

            bg-slate-900/40

            px-5
            py-2.5

            text-sm
            font-medium

            text-slate-300

            backdrop-blur-sm

            transition-all
            duration-200

            hover:border-cyan-400/30
            hover:bg-slate-900/60
            hover:text-slate-100
          "
        >
          Download CV
        </a>

      </div>

    </div>

  </div>

</section>