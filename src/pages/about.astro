---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About | Pol Ballesteros"
  description="Professional profile focused on artificial intelligence, embedded systems and applied research."
>

  <main>

    <!-- HERO -->

    <section class="container-base section-spacing">

      <div class="container-reading">

        <p class="text-sm uppercase tracking-[0.25em] text-secondary mb-6">
          Professional Profile
        </p>

        <h1 class="heading-xl mb-8">
          About Me
        </h1>

        <p class="text-xl text-secondary leading-relaxed">

          Electronic engineer and AI master's student focused on
          machine learning, embedded systems, IoT architectures,
          computer vision and applied technological research.

        </p>

      </div>

    </section>

    <!-- PROFILE -->

    <section class="container-base pb-24">

      <div class="grid lg:grid-cols-2 gap-16">

        <!-- LEFT -->

        <div>

          <h2 class="heading-lg mb-8">
            Professional Profile
          </h2>

          <div class="space-y-6 text-secondary leading-relaxed">

            <p>

              Experience in scientific research,
              industrial environments and technical development
              involving embedded systems, artificial intelligence
              and wireless communication technologies.

            </p>

            <p>

              Participation in academic projects related to
              propagation analysis, IoT systems,
              machine learning and computer vision.

            </p>

            <p>

              Technical focus oriented toward
              practical implementation,
              experimentation,
              optimization and applied engineering solutions.

            </p>

          </div>

        </div>

        <!-- RIGHT -->

        <div>

          <div class="card-base p-8 h-full">

            <h2 class="heading-lg mb-8">
              Core Areas
            </h2>

            <div class="space-y-6">

              <div>

                <h3 class="text-lg font-semibold mb-3">
                  Artificial Intelligence
                </h3>

                <p class="text-secondary leading-relaxed">
                  Machine learning,
                  computer vision,
                  predictive systems and data analysis.
                </p>

              </div>

              <div>

                <h3 class="text-lg font-semibold mb-3">
                  Embedded Systems
                </h3>

                <p class="text-secondary leading-relaxed">
                  ESP32, STM32,
                  sensors, IoT systems and hardware integration.
                </p>

              </div>

              <div>

                <h3 class="text-lg font-semibold mb-3">
                  Research
                </h3>

                <p class="text-secondary leading-relaxed">
                  Propagation analysis,
                  wireless systems and technical experimentation.
                </p>

              </div>

            </div>

          </div>

        </div>

      </div>

    </section>

    <!-- TECHNICAL APPROACH -->

    <section class="container-base pb-24">

      <div class="container-reading">

        <h2 class="heading-lg mb-10">
          Technical Approach
        </h2>

        <div class="space-y-6 text-secondary leading-relaxed">

          <p>

            Development oriented toward
            scalable architectures,
            maintainable systems,
            experimental validation and practical implementation.

          </p>

          <p>

            Interest in combining
            artificial intelligence,
            embedded systems and wireless communication
            for real-world engineering applications.

          </p>

          <p>

            Continuous focus on
            technical documentation,
            reproducibility,
            modular development and research-driven methodologies.

          </p>

        </div>

      </div>

    </section>

    <!-- WORK PHILOSOPHY -->

    <section class="container-base pb-24">

      <div class="grid md:grid-cols-3 gap-6">

        <article class="card-base p-8">

          <h3 class="text-xl font-semibold mb-4">
            Research-Oriented
          </h3>

          <p class="text-secondary leading-relaxed">

            Engineering supported by experimentation,
            technical analysis and measurable validation.

          </p>

        </article>

        <article class="card-base p-8">

          <h3 class="text-xl font-semibold mb-4">
            Multidisciplinary
          </h3>

          <p class="text-secondary leading-relaxed">

            Integration of software,
            electronics,
            AI and networking technologies.

          </p>

        </article>

        <article class="card-base p-8">

          <h3 class="text-xl font-semibold mb-4">
            Practical Development
          </h3>

          <p class="text-secondary leading-relaxed">

            Focus on implementation,
            optimization and functional technical solutions.

          </p>

        </article>

      </div>

    </section>

    <!-- PROFESSIONAL OBJECTIVES -->

    <section class="container-base pb-32">

      <div class="card-base p-10">

        <div class="container-reading">

          <h2 class="heading-lg mb-8">
            Professional Objectives
          </h2>

          <div class="space-y-6 text-secondary leading-relaxed">

            <p>

              Continue developing technologies related to
              artificial intelligence,
              embedded systems and intelligent sensing platforms.

            </p>

            <p>

              Participate in research,
              applied engineering and multidisciplinary projects
              involving AI-driven systems and wireless technologies.

            </p>

            <p>

              Contribute to the development of
              scalable technical solutions with scientific
              and industrial applicability.

            </p>

          </div>

        </div>

      </div>

    </section>

  </main>

</BaseLayout>