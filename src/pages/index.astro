---
import BaseLayout from "../layouts/BaseLayout.astro";
import { asset } from "../lib/assets";
import TechSection from "../islands/TechSection";

const quickLinks = [
  {
    title: "Projects",
    href: "/projects",
    description: "Research, AI and embedded systems."
  },
  {
    title: "Research",
    href: "/research",
    description: "Papers, technical reports and publications."
  },
  {
    title: "Experience",
    href: "/experience",
    description: "Industrial and academic background."
  }
];
---

<BaseLayout
  title="Pol Ballesteros | AI Engineer"
  description="Technical portfolio focused on artificial intelligence, embedded systems and applied research."
>

  <main>

    <!-- HERO -->
    <section
      class="
        container-base
        relative
        overflow-hidden
      "
    >

      <!-- BACKGROUND -->

      <div class="absolute inset-0 -z-10">

        <div class="
          absolute inset-0
          bg-gradient-to-br
          from-slate-950
          via-slate-900
          to-slate-950
        "></div>

        <div class="
          absolute top-0 right-0
          w-96 h-96
          bg-blue-500/20
          rounded-full
          blur-3xl
          opacity-30
        "></div>

        <div class="
          absolute bottom-0 left-0
          w-72 h-72
          bg-cyan-500/10
          rounded-full
          blur-3xl
          opacity-20
        "></div>

      </div>

      <!-- CONTENT -->

      <div
        class="
          relative
          z-10

          flex
          flex-col
          lg:flex-row

          items-center
          lg:items-center

          justify-between

          gap-8
          lg:gap-16

          py-10
          lg:py-0

          min-h-[235px]
        "
      >

        <!-- LEFT -->

        <div
          class="
            flex
            flex-col
            sm:flex-row

            items-center
            sm:items-center

            text-center
            sm:text-left

            gap-5
            lg:gap-6

            w-full
            lg:w-auto
          "
        >

          <!-- IMAGE -->

          <img
            src={asset("/images/me/PolBallesteros.jpeg")}
            alt="Pol Ballesteros"
            class="
              w-24
              h-24
              lg:w-28
              lg:h-28

              rounded-full
              object-cover

              ring-2
              ring-blue-500/30

              flex-shrink-0
            "
          />

          <!-- TEXT -->

          <div>

            <p
              class="
                mb-3

                tracking-[0.18em]
                uppercase

                text-[10px]
                sm:text-[11px]

                text-slate-300
              "
            >
              Artificial Intelligence • Embedded Systems • Research
            </p>

            <h1
              class="
                text-2xl
                sm:text-3xl
                lg:text-4xl

                font-semibold

                leading-[1.05]
                tracking-tight

                text-slate-100
              "
            >
              Pol Alexander<br />
              Ballesteros Quiroga
            </h1>

          </div>

        </div>

        <!-- RIGHT -->

        <div
          class="
            flex
            flex-col

            items-center
            lg:items-end

            w-full
            lg:w-auto
          "
        >

          <!-- CTA -->

          <div
            class="
              flex
              flex-col
              sm:flex-row

              w-full
              sm:w-auto

              gap-3
            "
          >

            <a
              href="/projects"
              class="
                bg-accent
                hover:bg-accent-hover

                transition
                duration-150
                ease-out
                transform
                hover:-translate-y-0.5
                active:translate-y-0.5
                active:scale-95

                px-5
                py-3

                rounded-xl

                text-sm
                font-medium
                text-white

                text-center
                focus:outline-none
                focus:ring-2
                focus:ring-blue-400/40
              "
            >
              View Projects
            </a>

            <a
              href={asset("/documents/CV_Pol_Ballesteros.pdf")}
              target="_blank"
              class="
                border
                border-border

                hover:border-accent
                hover:bg-slate-900/10

                transition
                duration-150
                ease-out
                transform
                hover:-translate-y-0.5
                active:translate-y-0.5
                active:scale-95

                px-5
                py-3

                rounded-xl

                text-sm
                font-medium
                text-slate-100

                text-center
                focus:outline-none
                focus:ring-2
                focus:ring-blue-400/30
              "
            >
              Download CV
            </a>

          </div>

        </div>

      </div>

    </section>

    <section class="container-base pb-24">
      <div class="mb-10">
        <h2 class="text-3xl font-semibold mb-4 mt-4">
          About Me
        </h2>
        <p class="text-text-secondary max-w-6xl">
          Electronic engineer and AI master's student focused on
          machine learning, embedded systems, IoT architectures,
          computer vision and propagation analysis.
        </p>
        <h2 class="text-3xl font-semibold mb-4 mt-4">
          Education
        </h2>
        <p class="text-text-secondary max-w-6xl">
          • Engineering Degree in Electronics, Universidad Privada del Valle (Cochabamba, Bolivia) - 2025<br />
          • Diploma in Artificial Intelligence & Machine Learning, Universidad Privada Franz Tamayo (Cochabamba, Bolivia) - 2026<br />
          • Master's Degree in Artificial Intelligence, Pontificia Universidad Católica de Chile (Santiago, Chile) - Present
        </p>
        <h2 class="text-3xl font-semibold mb-4 mt-4">
          Core Technologies
        </h2>
        <p class="text-text-secondary max-w-6xl">
          Technologies used in machine learning,
          embedded systems, scientific development and
          industrial applications.
        </p>
      </div>
      <TechSection client:load />
    </section>

    <!-- FEATURED PROJECT -->

    <section class="container-base pb-24">

      <div class="mb-10">

        <h2 class="text-3xl font-semibold mb-4">
          Featured Research Project
        </h2>

        <p class="text-text-secondary max-w-2xl">
          AI-assisted propagation analysis system
          for LoRa and wireless communication environments.
        </p>

      </div>

      <article class="
        bg-card
        border border-border
        rounded-card
        overflow-hidden
      ">

        <div class="grid lg:grid-cols-2">

          <!-- IMAGE -->

          <div class="min-h-[320px] bg-slate-900">

            <img
              src="/images/projects/lora/main.webp"
              alt="LoRa AI Propagation"
              class="w-full h-full object-cover"
              loading="lazy"
            />

          </div>

          <!-- CONTENT -->

          <div class="p-8 flex flex-col justify-between">

            <div>

              <div class="flex flex-wrap gap-2 mb-6">

                <span class="
                  px-3 py-1
                  rounded-lg
                  bg-slate-800
                  text-sm text-slate-300
                ">
                  Machine Learning
                </span>

                <span class="
                  px-3 py-1
                  rounded-lg
                  bg-slate-800
                  text-sm text-slate-300
                ">
                  Computer Vision
                </span>

                <span class="
                  px-3 py-1
                  rounded-lg
                  bg-slate-800
                  text-sm text-slate-300
                ">
                  IoT
                </span>

              </div>

              <h3 class="text-3xl font-semibold mb-6">
                LoRa Propagation AI
              </h3>

              <p class="text-text-secondary leading-relaxed mb-8">

                Predictive propagation platform using
                computer vision, geospatial analysis and
                machine learning to estimate wireless
                signal behavior in urban environments.

              </p>

              <div class="grid grid-cols-2 gap-6 mb-8">

                <div>

                  <p class="text-3xl font-bold mb-2">
                    92%
                  </p>

                  <p class="text-sm text-text-secondary">
                    Prediction Accuracy
                  </p>

                </div>

                <div>

                  <p class="text-3xl font-bold mb-2">
                    CNN
                  </p>

                  <p class="text-sm text-text-secondary">
                    Vision Architecture
                  </p>

                </div>

              </div>

            </div>

            <!-- LINKS -->

            <div class="flex flex-wrap gap-4">

              <a
                href="/projects/lora-propagation-ai"
                class="
                  bg-accent
                  hover:bg-accent-hover
                  transition-colors
                  px-5 py-3
                  rounded-xl
                  font-medium
                "
              >
                View Project
              </a>

              <a
                href="https://github.com/polbq"
                target="_blank"
                class="
                  border border-border
                  hover:border-accent
                  transition-colors
                  px-5 py-3
                  rounded-xl
                  font-medium
                "
              >
                GitHub
              </a>

            </div>

          </div>

        </div>

      </article>

    </section>

    <!-- QUICK ACCESS -->

    <section class="container-base pb-32">

      <div class="mb-10">

        <h2 class="text-3xl font-semibold mb-4">
          Technical Sections
        </h2>

        <p class="text-text-secondary max-w-2xl">
          Quick access to projects,
          publications and technical experience.
        </p>

      </div>

      <div class="grid md:grid-cols-3 gap-6">

        {
          quickLinks.map((item) => (

            <a
              href={asset(item.href)}
              class="
                bg-card
                border border-border
                hover:border-accent
                transition-colors
                rounded-card
                p-6
              "
            >

              <h3 class="text-xl font-semibold mb-4">
                {item.title}
              </h3>

              <p class="text-text-secondary leading-relaxed">
                {item.description}
              </p>

            </a>

          ))
        }

      </div>

    </section>

    <!-- CONTACT CTA -->

    <section class="container-base pb-32">

      <div class="
        border border-border
        rounded-card
        p-10
        bg-card
      ">

        <div class="max-w-3xl">

          <h2 class="text-3xl font-semibold mb-6">
            Research and Technical Collaboration
          </h2>

          <p class="text-text-secondary leading-relaxed mb-8">

            Open to opportunities related to
            machine learning, embedded systems,
            research projects and applied AI development.

          </p>

          <div class="flex flex-wrap gap-4">

            <a
              href={asset("/contact")}
              class="
                bg-accent
                hover:bg-accent-hover
                transition-colors
                px-6 py-3
                rounded-xl
                font-medium
              "
            >
              Contact
            </a>

            <a
              href="https://github.com/polbq"
              target="_blank"
              class="
                border border-border
                hover:border-accent
                transition-colors
                px-6 py-3
                rounded-xl
                font-medium
              "
            >
              GitHub
            </a>

            <a
              href="https://gitlab.com/"
              target="_blank"
              class="
                border border-border
                hover:border-accent
                transition-colors
                px-6 py-3
                rounded-xl
                font-medium
              "
            >
              GitLab
            </a>

          </div>

        </div>

      </div>

    </section>

  </main>

</BaseLayout>