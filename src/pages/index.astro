---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/layout/Hero.astro";
import Footer from "../components/layout/Footer.astro";
import { asset } from "../lib/assets";
import TechSection from "../islands/TechSection";
import ProjectsCarousel from "../islands/ProjectsCarousel";
import PublicationsSection from "../components/publications/PublicationsSection.astro";

const quickLinks = [
  {
    title: "Projects",
    href: "/projects",
    description: "Research, AI and embedded systems."
  },
  {
    title: "Research",
    href: "/research",
    description: "Papers, technical reports and publications."
  },
  {
    title: "Experience",
    href: "/experience",
    description: "Industrial and academic background."
  }
];
---

<BaseLayout
  title="Pol Ballesteros | AI Engineer"
  description="Technical portfolio focused on artificial intelligence, embedded systems and applied research."
>

  <main>
    <section>
      <Hero />
    </section>

    <section class="container-base pb-24">
      <div class="mb-10">
        <h2 class="text-3xl font-semibold mb-4 mt-4">
          About Me
        </h2>
        <p class="text-text-secondary max-w-6xl">
          Electronic engineer and AI master's student focused on
          machine learning, embedded systems, IoT architectures,
          computer vision and propagation analysis.
        </p>
        <h2 class="text-3xl font-semibold mb-4 mt-4">
          Education
        </h2>
        <p class="text-text-secondary max-w-6xl">
          • Engineering Degree in Electronics, Universidad Privada del Valle (Cochabamba, Bolivia) - 2025<br />
          • Diploma in Artificial Intelligence & Machine Learning, Universidad Privada Franz Tamayo (Cochabamba, Bolivia) - 2026<br />
          • Master's Degree in Artificial Intelligence, Pontificia Universidad Católica de Chile (Santiago, Chile) - Present
        </p>
        <h2 class="text-3xl font-semibold mb-4 mt-4">
          Core Technologies
        </h2>
        <p class="text-text-secondary max-w-6xl">
          Technologies used in machine learning,
          embedded systems, scientific development and
          industrial applications.
        </p>
      </div>
      <TechSection client:load />
    </section>

    <!-- FEATURED PROJECT -->

    <section class="container-base pb-24">

      <div class="mb-10">
        <PublicationsSection />
        <h2 class="text-3xl font-semibold mb-4 mt-4">
          Featured Research Project
        </h2>
      </div>
      <ProjectsCarousel client:load />
    </section>
    <Footer />
  </main>

</BaseLayout>