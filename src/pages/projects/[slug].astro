---
import BaseLayout from "../../layouts/BaseLayout.astro";

import {
  getCollection,
  render
} from "astro:content";

export async function getStaticPaths() {

  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: {
      slug: project.slug
    },

    props: {
      project
    }
  }));
}

const { project } = Astro.props;

const {
  title,
  description,
  technologies,
  github,
  gitlab,
  documentation,
  gallery,
  metrics
} = project.data;

const { Content } = await render(project);
---

<BaseLayout
  title={title}
  description={description}
>

  <main>

    <!-- HERO -->

    <section class="container-base section-spacing">

      <div class="container-reading">

        <h1 class="heading-xl mb-8">
          {title}
        </h1>

        <p class="text-xl text-secondary leading-relaxed">
          {description}
        </p>

      </div>

    </section>

    <!-- TECHNOLOGIES -->

    <section class="container-base pb-16">

      <div class="flex flex-wrap gap-3">

        {
          technologies.map((tech: string) => (

            <span class="badge-tech">
              {tech}
            </span>

          ))
        }

      </div>

    </section>

    <!-- GALLERY -->

    {
      gallery && (

        <section class="container-base pb-24">

          <div class="
            grid
            md:grid-cols-2
            gap-6
          ">

            {
              gallery.map((image: string) => (

                <img
                  src={image}
                  alt={title}
                  class="
                    rounded-card
                    border
                    border-border
                  "
                />

              ))
            }

          </div>

        </section>

      )
    }

    <!-- METRICS -->

    {
      metrics && (

        <section class="container-base pb-24">

          <div class="
            grid
            md:grid-cols-3
            gap-6
          ">

            <div class="card-base p-6">

              <p class="text-3xl font-bold mb-3">
                {metrics.accuracy ?? "--"}%
              </p>

              <p class="text-secondary">
                Accuracy
              </p>

            </div>

          </div>

        </section>

      )
    }

    <!-- CONTENT -->

    <section class="container-base pb-32">

      <article class="
        prose
        prose-invert
        max-w-none
      ">

        <Content />

      </article>

    </section>

  </main>

</BaseLayout>