---
interface Props {
  title: string;
  subtitle?: string;
}

const {
  title,
  subtitle
} = Astro.props;
---

<section class="max-w-6xl mx-auto px-6 py-20">

  <header class="mb-12">
    <h1 class="text-4xl font-bold mb-4">
      {title}
    </h1>

    {
      subtitle && (
        <p class="text-slate-400 max-w-3xl">
          {subtitle}
        </p>
      )
    }
  </header>

  <slot />

</section>