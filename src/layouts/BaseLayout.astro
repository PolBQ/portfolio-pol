---
import "../styles/globals.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Technical portfolio"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <meta
      name="description"
      content={description}
    />

    <title>{title}</title>
  </head>

  <body class="bg-slate-950 text-slate-200">
    <slot />
  </body>
</html>